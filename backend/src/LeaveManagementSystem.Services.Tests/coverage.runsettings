<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <ExcludeByFile>
            **/Program.cs,
            **/DependencyInjection.cs,
            **/DTOs/*.cs,
            **/Interfaces/*.cs,
            **/Entities/*.cs,
            **/Enums/*.cs,
            **/Common/LeaveStatuses.cs,
            **/Common/RoleNames.cs
          </ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
